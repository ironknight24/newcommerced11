{#
/**
 * Commerce cart form view wrapper.
 */
#}
{%
  set classes = [
    dom_id ? 'js-view-dom-id-' ~ dom_id,
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    'cb-cart-view',
    'mx-auto',
    'max-w-6xl',
    'px-4',
    'pb-8',
    'md:px-6',
  ]
%}
<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {{ title }}
  {{ title_suffix }}

  {% if header %}
    <header class="mb-4">{{ header }}</header>
  {% endif %}

  {{ exposed }}
  {{ attachment_before }}

  {% if rows %}
    {{ rows }}
  {% elseif empty %}
    {{ empty }}
  {% endif %}
  {{ pager }}

  {% if footer %}
    <footer class="cb-cart-view__footer mt-6 border-t border-slate-200 pt-6">
      {{ footer }}
    </footer>
  {% endif %}

  {{ attachment_after }}
  {{ more }}
  {{ feed_icons }}
</div>
