{#
/**
 * Cart line: court image, title, location (misk theme — styles in src/input.css).
 *
 * @see court_booking_preprocess_commerce_product_variation()
 */
#}
<div{{ attributes.addClass('cb-cart-variation') }}>
  <div class="cb-cart-variation__media">
    {% if cart_thumbnail_url %}
      <div class="cb-cart-variation__thumb" style="background-image: url('{{ cart_thumbnail_url|e('html_attr') }}')"></div>
    {% else %}
      <div class="cb-cart-variation__thumb cb-cart-variation__thumb--placeholder" aria-hidden="true"></div>
    {% endif %}
  </div>
  <div class="cb-cart-variation__body">
    {{- product_variation -}}
    {% if cart_location_label %}
      <p class="cb-cart-variation__location">
        <span class="cb-cart-variation__location-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/></svg>
        </span>
        <span class="cb-cart-variation__location-text">{{ cart_location_label }}</span>
      </p>
    {% endif %}
  </div>
</div>
