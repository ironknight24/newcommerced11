{% import _self as menus %}

<nav class="w-full">
  {{ menus.menu_links(items, attributes.addClass('flex justify-center items-center gap-8 py-4'), 0) }}
</nav>

{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}

  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes }}>
    {% else %}
      <ul class="mt-2 space-y-2">
    {% endif %}

    {% for item in items %}
      <li{{ item.attributes.addClass('relative') }}>

        {# Link styling #}
        {{ link(
          item.title,
          item.url,
          {
            'class': [
              'text-[#0033a1]',
              'font-semibold',
              'uppercase',
              'tracking-wide',
              'text-sm',
              'md:text-base',
              'hover:underline',
              'transition',
              'duration-200'
            ]
          }
        ) }}

        {# Dropdown (if exists) #}
        {% if item.below %}
          <div class="absolute left-0 mt-2 hidden group-hover:block bg-white shadow-lg rounded-md p-3 min-w-[150px]">
            {{ menus.menu_links(item.below, attributes, menu_level + 1) }}
          </div>
        {% endif %}

      </li>
    {% endfor %}

    </ul>
  {% endif %}
{% endmacro %}