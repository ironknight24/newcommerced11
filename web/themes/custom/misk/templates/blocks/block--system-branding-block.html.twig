{% extends "block.html.twig" %}

{% block content %}
  <div class="flex items-center gap-3 py-3">
    
    {% if site_logo %}
      <a href="{{ path('<front>') }}" rel="home" class="flex items-center">
        <img 
          src="{{ site_logo }}" 
          alt="{{ 'Home'|t }}" 
          class="h-10 w-auto object-contain"
          fetchpriority="high"
        />
      </a>
    {% endif %}

    {% if site_name %}
      <a 
        href="{{ path('<front>') }}" 
        rel="home" 
        class="text-lg font-semibold text-slate-800 hover:text-[#02216E] transition-colors"
      >
        {{ site_name }}
      </a>
    {% endif %}

    {% if site_slogan %}
      <span class="hidden sm:inline text-sm text-slate-500">
        {{ site_slogan }}
      </span>
    {% endif %}

  </div>
{% endblock %}