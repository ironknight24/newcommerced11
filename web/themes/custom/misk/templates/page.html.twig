<div class="min-h-screen bg-slate-50 text-slate-900">
  {% if page.header %}
    <header role="banner" class="border-b border-slate-200/80 bg-white/90 backdrop-blur-sm">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 md:px-6">
        {{ page.header }}
      </div>
    </header>
  {% endif %}
  <main id="main-content" role="main" class="">
    {{ page.content }}
  </main>
  {% if page.footer %}
    <footer role="contentinfo" class="border-t border-slate-200 bg-white">
      <div class="mx-auto max-w-7xl px-4 py-6 text-sm text-slate-500 md:px-6">
        {{ page.footer }}
      </div>
    </footer>
  {% endif %}
</div>
